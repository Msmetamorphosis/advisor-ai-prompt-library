{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/crm-note-assistant.json",
  "title": "CRM Note Assistant Output",
  "type": "object",
  "required": ["crm_note", "source_evidence", "review_flags", "missing_information"],
  "additionalProperties": false,
  "properties": {
    "crm_note": {
      "type": "string",
      "minLength": 30,
      "description": "Concise CRM-ready draft ending with 'Draft — pending advisor review.'"
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "source_excerpt"],
        "additionalProperties": false,
        "properties": {
          "claim": {"type": "string"},
          "source_excerpt": {"type": "string"}
        }
      }
    },
    "review_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "reason"],
        "additionalProperties": false,
        "properties": {
          "topic": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "missing_information": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
